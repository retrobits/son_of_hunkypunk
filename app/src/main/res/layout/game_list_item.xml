<?xml version="1.0" encoding="utf-8"?>
<!--
    Modern Material Design card layout for individual game items
-->
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.HunkyPunk.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="8dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="?attr/colorPrimary">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Game icon/thumbnail placeholder -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/game_icon_card"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/game_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_book_24"
                android:background="?attr/colorSurfaceVariant"
                android:contentDescription="Game icon" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Game title -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/game_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/game_icon_card"
            app:layout_constraintTop_toTopOf="@id/game_icon_card"
            app:layout_constraintEnd_toStartOf="@id/game_status_indicator"
            android:text="Game Title" />

        <!-- Game author -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/game_author"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/game_icon_card"
            app:layout_constraintTop_toBottomOf="@id/game_title"
            app:layout_constraintEnd_toStartOf="@id/game_status_indicator"
            android:text="Author Name" />

        <!-- Game progress/last played info -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/game_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorTertiary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/game_icon_card"
            app:layout_constraintTop_toBottomOf="@id/game_author"
            app:layout_constraintBottom_toBottomOf="@id/game_icon_card"
            app:layout_constraintEnd_toStartOf="@id/game_status_indicator"
            android:text="Last played: Yesterday" />

        <!-- Game status indicator (playing, completed, new, etc.) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/game_status_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="0dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/game_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:text="NEW" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Optional: Progress bar for games in progress -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/game_progress_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            app:indicatorColor="?attr/colorPrimary"
            app:trackColor="?attr/colorSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/game_icon_card"
            app:layout_constraintTop_toBottomOf="@id/game_progress"
            app:layout_constraintEnd_toStartOf="@id/game_status_indicator" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
